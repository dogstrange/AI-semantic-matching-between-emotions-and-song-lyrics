  "layers": [
    {
      "id": "layer:web-api",
      "name": "Web API",
      "description": "FastAPI web server: the HTTP entry point, the request schema, and the /face endpoint that drives the live recommendation flow.",
      "nodeIds": [
        "file:main.py",
        "file:api/interface/interface.py",
        "endpoint:main.py:post-face"
      ]
    },
    {
      "id": "layer:recommendation-pipeline",
      "name": "Recommendation Pipeline",
      "description": "Runtime emotion-to-song logic: per-frame emotion analysis, emotion ranking, CLAP text encoding, and vector querying.",
      "nodeIds": [
        "file:src/frame_processor.py",
        "file:src/emotions.py",
        "file:src/cam.py",
        "file:src/run.py"
      ]
    },
    {
      "id": "layer:ml-models",
      "name": "ML Models",
      "description": "Wrapped machine-learning models: the CLAP dual encoder and the facial-emotion / face-detection models.",
      "nodeIds": [
        "file:model/trans_model.py"
      ]
    },
    {
      "id": "layer:data-pipeline",
      "name": "Data Pipeline",
      "description": "Offline dataset preparation: scraping audio, encoding (lyrics, audio) pairs, and populating the vector stores.",
      "nodeIds": [
        "file:tools/clap_encode.py",
        "file:tools/create_db.py",
        "file:tools/scrape.py",
        "file:src/embed.py"
      ]
    },
    {
      "id": "layer:vector-stores",
      "name": "Vector Stores",
      "description": "ChromaDB collections holding song embeddings — built offline and queried at runtime.",
      "nodeIds": [
        "table:data/clap_db:clap-song-collection",
        "table:chroma_db:songs"
      ]
    },
    {
      "id": "layer:infrastructure",
      "name": "Infrastructure",
      "description": "Container build and multi-service orchestration (the app plus the Ollama LLM).",
      "nodeIds": [
        "service:Dockerfile",
        "service:docker-compose.yml"
      ]
    },
    {
      "id": "layer:config-and-docs",
      "name": "Config & Docs",
