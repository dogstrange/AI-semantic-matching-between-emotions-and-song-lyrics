  "tour": [
    {
      "order": 1,
      "title": "Project Overview",
      "description": "Start with the README to understand the goal: detect facial emotions from a webcam and recommend a matching song via CLAP and a vector database.",
      "nodeIds": [
        "document:README.md"
      ]
    },
    {
      "order": 2,
      "title": "Web Server Entry Point",
      "description": "main.py boots the FastAPI app, loads models once in the lifespan, and exposes POST /face — the seam where the browser hands frames to the pipeline.",
      "nodeIds": [
        "file:main.py",
        "endpoint:main.py:post-face"
      ]
    },
    {
      "order": 3,
      "title": "The Request Contract",
      "description": "FacialAnalyst is the Pydantic schema that types the /face request body: the base64 frames and session duration the frontend sends.",
      "nodeIds": [
        "file:api/interface/interface.py"
      ]
    },
    {
      "order": 4,
      "title": "Facial Emotion Analysis",
      "description": "frame_processor decodes each frame, detects faces, classifies emotions, and blends the 7 base emotions into a richer complex-emotion vocabulary.",
      "nodeIds": [
        "file:src/frame_processor.py"
      ]
    },
    {
      "order": 5,
      "title": "The ML Models",
      "description": "trans_model wraps the two model families the pipeline depends on: the CLAP dual encoder (text + audio) and the facial emotion classifier with MTCNN.",
      "nodeIds": [
        "file:model/trans_model.py"
      ]
    },
    {
      "order": 6,
      "title": "Emotion to Song",
      "description": "emotions.py is the recommendation core: rank emotions, rephrase them with a local LLM, CLAP-encode the sentence, and query the vector store for the closest song.",
      "nodeIds": [
        "file:src/emotions.py"
      ]
    },
    {
      "order": 7,
      "title": "The Vector Stores",
      "description": "Two ChromaDB collections back the system: the runtime clap-song-collection (text+audio embeddings) and the legacy \"songs\" lyric collection used during scraping.",
      "nodeIds": [
        "table:data/clap_db:clap-song-collection",
        "table:chroma_db:songs"
      ]
    },
    {
      "order": 8,
      "title": "Building the Song Database",
      "description": "The offline data pipeline: scrape.py downloads audio, create_db.py and clap_encode.py encode each (lyrics, audio) pair and populate clap-song-collection.",
      "nodeIds": [
        "file:tools/scrape.py",
        "file:tools/create_db.py",
        "file:tools/clap_encode.py"
      ]
    },
    {
      "order": 9,
      "title": "The Original CLI Pipeline",
      "description": "Before the web app, run.py + cam.py drove the same flow locally: a live webcam session feeding the emotion ranking and song lookup.",
      "nodeIds": [
        "file:src/run.py",
        "file:src/cam.py"
      ]
    },
    {
      "order": 10,
      "title": "Containerization & Deployment",
      "description": "The Dockerfile packages the app and prebuilt vector DB behind uvicorn; docker-compose adds the Ollama LLM service the recommender calls for emotion rephrasing.",
      "nodeIds": [
        "service:Dockerfile",
        "service:docker-compose.yml"
      ]
    }
  ]
}